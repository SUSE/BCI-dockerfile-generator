<services>
  <service name="docker_label_helper" mode="buildtime" />
  <service name="kiwi_metainfo_helper" mode="buildtime" />
  <service name="replace_using_package_version" mode="buildtime">
    <param name="file">Dockerfile</param>
    <param name="regex">%%pg_minor_version%%</param>
    <param name="package">postgresql13-server</param>
    <param name="parse-version">minor</param>
  </service>
  <service name="replace_using_package_version" mode="buildtime">
    <param name="file">Dockerfile</param>
    <param name="regex">%%pg_patch_version%%</param>
    <param name="package">postgresql13-server</param>
    <param name="parse-version">patch</param>
  </service>
</services>
#!UseOBSRepositories
#!ExclusiveArch: x86_64
#!BuildTag: third-party/amd/amdgpu-driver:sles-%OS_VERSION_ID_SP%-31.30-%RELEASE%
#!BuildTag: third-party/amd/amdgpu-driver:sles-%OS_VERSION_ID_SP%-31.30
#!BuildTag: third-party/amd/amdgpu-driver:sles-16.0-6.12.0-160000.5-default-31.30
#!BcntSyncTag: amd-driver-image
#!BuildName: amd-driver-31.30
#!BuildVersion: 16.0.31.30
FROM registry.suse.com/bci/bci-micro:16.0 AS target
FROM registry.suse.com/bci/bci-base:16.0 AS builder
COPY --from=target / /target
RUN set -euo pipefail; zypper -n install --no-recommends awk dwarves elfutils gcc libelf-devel pesign-obs-integration zstd autoconf automake bc bison dracut flex gawk libzstd-devel make mokutil perl perl-Bootloader python3 python3-setuptools python3-wheel gcc13 suse-kernel-rpm-scriptlets
RUN set -euo pipefail; \
    export PERMCTL_ALLOW_INSECURE_MODE_IF_NO_PROC=1; \
    zypper -n --installroot /target --gpg-auto-import-keys install --no-recommends rpm kmod SLES-release
RUN mkdir -p /tmp/
#!RemoteAssetUrl: https://repo.radeon.com/amdgpu/31.30/sle/16.0/main/x86_64/amdgpu-dkms-6.19.4.31300000-2337710.noarch.rpm amdgpu-dkms-6.19.4.31300000-2337710.x86_64.rpm sha256:abf2d82d9ea56649f128988e9c994dcab867c79d37697c9ff60091c59e45e479
COPY amdgpu-dkms-6.19.4.31300000-2337710.x86_64.rpm /tmp/
#!RemoteAssetUrl: https://repo.radeon.com/amdgpu/31.30/sle/16.0/main/x86_64/amdgpu-dkms-firmware-31.30.0.0.31300000-2337710.noarch.rpm amdgpu-dkms-firmware-31.30.0.0.31300000-2337710.x86_64.rpm sha256:4ad7649c684416245edb08a67675bbb3e0d3ddd9cfffcf3a73dff44eca0d6fe4
COPY amdgpu-dkms-firmware-31.30.0.0.31300000-2337710.x86_64.rpm /tmp/
#!RemoteAssetUrl: https://repo.radeon.com/amdgpu/31.30/sle/16.0/main/x86_64/dkms-3.1.7-bp160.1.3.noarch.rpm dkms-3.1.7-bp160.1.3.x86_64.rpm sha256:2b45129bcfd660abcd7db6d89f7e3d023b6730248906def850bab25cd0df72a9
COPY dkms-3.1.7-bp160.1.3.x86_64.rpm /tmp/
#!RemoteAssetUrl: https://api.opensuse.org/public/build/SUSE:SLFO:1.2/standard/x86_64/patchinfo.ga/kernel-default-6.12.0-160000.5.1.x86_64.rpm
COPY kernel-default-6.12.0-160000.5.1.x86_64.rpm /tmp/
#!RemoteAssetUrl: https://api.opensuse.org/public/build/SUSE:SLFO:1.2/standard/x86_64/patchinfo.ga/kernel-default-devel-6.12.0-160000.5.1.x86_64.rpm
COPY kernel-default-devel-6.12.0-160000.5.1.x86_64.rpm /tmp/
#!RemoteAssetUrl: https://api.opensuse.org/public/build/SUSE:SLFO:1.2/standard/x86_64/patchinfo.ga/kernel-syms-6.12.0-160000.5.1.x86_64.rpm
COPY kernel-syms-6.12.0-160000.5.1.x86_64.rpm /tmp/
#!RemoteAssetUrl: https://api.opensuse.org/public/build/SUSE:SLFO:1.2/standard/x86_64/patchinfo.ga/kernel-devel-6.12.0-160000.5.1.noarch.rpm kernel-devel-6.12.0-160000.5.1.x86_64.rpm
COPY kernel-devel-6.12.0-160000.5.1.x86_64.rpm /tmp/
#!RemoteAssetUrl: https://api.opensuse.org/public/build/SUSE:SLFO:1.2/standard/x86_64/patchinfo.ga/kernel-macros-6.12.0-160000.5.1.noarch.rpm kernel-macros-6.12.0-160000.5.1.x86_64.rpm
COPY kernel-macros-6.12.0-160000.5.1.x86_64.rpm /tmp/

COPY radeon-31.30-x86_64.gpg.key /tmp/radeon-31.30-x86_64.gpg.key
RUN rpm --import /tmp/radeon-31.30-x86_64.gpg.key


RUN if [ "$(uname -m)" = "x86_64" ]; then \
        zypper -n install \
            /tmp/amdgpu-dkms-6.19.4.31300000-2337710.x86_64.rpm \
            /tmp/amdgpu-dkms-firmware-31.30.0.0.31300000-2337710.x86_64.rpm \
            /tmp/dkms-3.1.7-bp160.1.3.x86_64.rpm \
            /tmp/kernel-default-6.12.0-160000.5.1.x86_64.rpm \
            /tmp/kernel-default-devel-6.12.0-160000.5.1.x86_64.rpm \
            /tmp/kernel-syms-6.12.0-160000.5.1.x86_64.rpm \
            /tmp/kernel-devel-6.12.0-160000.5.1.x86_64.rpm \
            /tmp/kernel-macros-6.12.0-160000.5.1.x86_64.rpm; \
    fi

COPY radeon-31.30-x86_64.repo /etc/zypp/repos.d/radeon-31.30-x86_64.repo

RUN rm -rf /tmp/*

# decompress modules for getKmodsToSign (kmmmodule.go) since it expects uncompressed files
RUN set -euo pipefail; \
    find /lib/modules/6.12.0-160000.5-default -name "*.ko.zst" -exec zstd -d --rm {} \;; \
    depmod -m /lib/modules 6.12.0-160000.5-default

# copy modules to /opt since getKmodsToSign (kmmmodule.go) expects it there
RUN set -euo pipefail; \
    mkdir -p /target/opt/lib/modules/6.12.0-160000.5-default/updates/dkms; \
    cp /lib/modules/6.12.0-160000.5-default/updates/amd* /target/opt/lib/modules/6.12.0-160000.5-default/updates/dkms; \
    cp /lib/modules/6.12.0-160000.5-default/modules.* /target/opt/lib/modules/6.12.0-160000.5-default/; \
    cp -r /lib/modules/6.12.0-160000.5-default/kernel /target/opt/lib/modules/6.12.0-160000.5-default/kernel; \
    depmod -m /lib/modules -b /target/opt 6.12.0-160000.5-default

# copy firmware to /firmwareDir
RUN set -euo pipefail; \
    mkdir -p /target/firmwareDir/updates/amdgpu; \
    cp -r /lib/firmware/updates/amdgpu/* /target/firmwareDir/updates/amdgpu; \
    install -p -D /usr/share/doc/packages/amdgpu-dkms-firmware/LICENSE /target/usr/share/licenses/amdgpu-dkms-firmware/LICENSE

RUN set -euo pipefail; if rpm --root /target -q compat-usrmerge-tools; then rpm --root /target -e compat-usrmerge-tools; fi

# cleanup logs and temporary files
RUN set -euo pipefail; zypper -n --installroot /target clean -a; \
    t=$(mktemp -d); mv /target/usr/lib/sysimage/rpm/Packages.db $t; rpmdb --rebuilddb --dbpath=$t; \
    rm /target/usr/lib/sysimage/rpm/*.db && mv $t/Packages.db /target/usr/lib/sysimage/rpm/; \
    rm -rf {/target,}/var/log/{alternatives.log,lastlog,suseconnect.log,tallylog,zypper.log,zypp/history,YaST2}; \
    rm -rf {/target,}/run/*; \
    rm -f {/target,}/etc/{shadow-,group-,passwd-,.pwd.lock}; \
    rm -f {/target,}/usr/lib/sysimage/rpm/.rpm.lock; \
    rm -f {/target,}/var/lib/zypp/AnonymousUniqueId; \
    rm -f {/target,}/var/lib/zypp/AutoInstalled; \
    rm -f {/target,}/var/cache/ldconfig/aux-cache

# set the day of last password change to empty
RUN set -euo pipefail; sed -i 's/^\([^:]*:[^:]*:\)[^:]*\(:.*\)$/\1\2/' /target/etc/shadow
FROM registry.suse.com/bci/bci-micro:16.0
COPY --from=builder /target /
